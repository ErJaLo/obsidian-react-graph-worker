name = "obsidian-worker"
main = "src/index.js"
compatibility_date = "2024-01-01"

[[kv_namespaces]]
binding = "APP_KV"
id = "<PRODUCTION_KV_NAMESPACE_ID>"
preview_id = "<PREVIEW_KV_NAMESPACE_ID>"

[vars]
GITHUB_OWNER = "<github-owner-or-org>"
GITHUB_REPO = "<github-repo>"
GITHUB_BRANCH = "main"
ENABLE_GITHUB_WEBHOOKS = "false"
